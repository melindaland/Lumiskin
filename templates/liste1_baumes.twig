{% extends 'base.twig' %}

{% block main %}
<div class="content-with-aside">
    <aside>
        <h3>Filtrer les produits</h3>
        <form action="liste1_baumes.php" method="GET">
            <h4>Marque</h4>
            <ul>
                {% for marque in marques %}
                <li>
                    <input type="checkbox" name="marque[]" id="marque{{ marque.id_marque }}"
                        value="{{ marque.id_marque }}">
                    <label for="marque{{ marque.id_marque }}">{{ marque.nom_marque }}</label>
                </li>
                {% endfor %}
            </ul>
            <h4>Type de peau</h4>
            <ul>
                {% for type_peau in types_peau %}
                <li>
                    <input type="checkbox" name="type_peau[]" id="peau_{{ type_peau.id_type }}"
                        value="{{ type_peau.id_type }}">
                    <label for="peau_{{ type_peau.id_type }}">{{ type_peau.nom_type }}</label>
                </li>
                {% endfor %}
            </ul>
            <button type="submit">Filtrer</button>
            <div class="bouton-retour">
                <a href="liste1_baumes.php">Retour vers Tous les baumes</a>
            </div>
            <div class="bouton-retour1">
                <a href="liste_produits.php">Retour vers Tous les Produits</a>
            </div>


        </form>
    </aside>

    <div class="main-content">
        <h2>Liste des Baumes</h2>
        <p>Que vous recherchiez une hydratation intense, une purification en profondeur ou une revitalisation instantanée, nos
        baumes de soin sont le secret d'une peau éclatante de santé. Transformez votre routine de soin et découvrez une peau
        visiblement plus belle dès aujourd'hui.</p>
        {% if articles_baumes|length > 0 %}
        <h4>Nombre d'articles trouvés : {{ articles_baumes|length }}</h3>
        <div class="articles-container">
            {% for article in articles_baumes %}
            <div class="articles_vignette">
                <p class="article-texte"> {{ article.nom_article }}</p>
                <img src="{{ article.image }}" alt="{{ article.nom_article }}">
                <div class="bouton-detail">
                    <a href="detail1_baumes.php?id={{ article.id_article }}">Voir détail</a>
                </div>
            </div>
            {% endfor %}
        </div>
        {% else %}
        <p>Aucun article trouvé dans la catégorie "Baumes".</p>
        {% endif %}
    </div>
</div>
{% endblock %}